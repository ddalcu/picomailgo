# PicoMailGo Configuration (all env vars, no config files)

# Domain name for this mail server
MAIL_DOMAIN=example.com

# JWT secret for authentication (use a strong random value)
JWT_SECRET=change-me

# Data directory (SQLite DB, DKIM keys)
DATA_DIR=./data

# Web server
WEB_LISTEN=:8080
HTTP_LISTEN=:80

# SMTP
SMTP_INBOUND_LISTEN=:2525
SMTP_SUBMISSION_LISTEN=:5587

# IMAP
IMAP_LISTEN=:9993

# TLS (mode: none, autocert, manual)
TLS_MODE=none
TLS_CERT_FILE=
TLS_KEY_FILE=
